{
    "geode": "4.0.0",
    "id": "fabygamer1277.fps-optimizer",
    "version": "1.0.0",
    "name": "FPS Optimizer",
    "developer": "Fabygamer1277",
    "description": "Optimiza los FPS y TPS de tu juego de manera sencilla.",
    "dependencies": [
        {
            "id": "theyareonit.click-between-frames",
            "version": "v1.1.3",
            "importance": "recommended"
        }
    ],
    "settings": {
        "tps": {
            "name": "Target TPS",
            "description": "Ticks por segundo por defecto para las físicas.",
            "type": "int",
            "default": 60,
            "min": 15,
            "max": 1000
        },
        "fps": {
            "name": "Target FPS",
            "description": "Cuadros por segundo por defecto.",
            "type": "int",
            "default": 60,
            "min": 15,
            "max": 1000
        }
    }
}
